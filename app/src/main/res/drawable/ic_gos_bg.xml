<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Step 1: Create the white rounded background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/colorOnPrimary" />
            <corners android:radius="2dp" /> <!-- Adjust radius as needed -->
        </shape>
    </item>

    <!-- Step 2: Overlay your existing drawable -->
    <item
        android:drawable="@drawable/ic_gos"
        android:top="5dp"
        android:bottom="2dp"
        android:left="4dp"
        android:right="3dp" /> <!-- Use insets to create space/padding -->
</layer-list>